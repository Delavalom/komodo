# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/komodo

# NextAuth secret (generate with: openssl rand -base64 32)
AUTH_SECRET=your-secret-here

# GitHub OAuth App credentials (scope: repo read:user)
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# OpenRouter API key (platform key — users are billed via credits, not their own keys)
OPENROUTER_API_KEY=sk-or-...

# Dev top-up (set to "true" to enable the /api/credits/dev-topup endpoint)
DEV_TOPUP_ENABLED=false

# Polar.sh billing (optional — omit to disable paid credit packs and show dev top-up instead)
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_500=
POLAR_PRODUCT_2000=
POLAR_PRODUCT_10000=
