  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.0",
    "picomatch": "^4.0.2",
    "yaml": "^2.6.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/picomatch": "^4.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
