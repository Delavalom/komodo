{
  "name": "@komodo/core",
  "version": "0.1.0",
  "description": "Provider-agnostic AI code review engine for Komodo",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
